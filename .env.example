# ──────────────────────────────────────────────────────────────────
#  Sacred Waste Bot - Configuration Template
#  1. Copy file ini: cp .env.example .env
#  2. Isi .env dengan data kamu
#  3. JANGAN pernah commit file .env ke Git!
# ──────────────────────────────────────────────────────────────────

# ── WALLETS ────────────────────────────────────────────────────────
# Tambah wallet sebanyak yang dibutuhkan (PK_1, PK_2, dst)
# Format proxy: http://user:pass@host:port atau socks5://user:pass@host:port
#
# SW_TOKEN: JWT dari browser untuk voting.
# Cara dapat:
#   1. Buka https://app.sacredwaste.io, connect wallet
#   2. DevTools → Console → localStorage.getItem('sw_token')
#   3. Copy hasilnya ke SW_TOKEN_N
#   Token berlaku 7-30 hari.

PK_1=0x_YOUR_PRIVATE_KEY
PROXY_1=
SW_TOKEN_1=

PK_2=0x_YOUR_PRIVATE_KEY
PROXY_2=
SW_TOKEN_2=

PK_3=
PROXY_3=
SW_TOKEN_3=

# ── NETWORK ────────────────────────────────────────────────────────
RPC_URL=https://mainnet.base.org
CHAIN_ID=8453

# ── CONTRACTS ─────────────────────────────────────────────────────
# TOKEN_CONTRACT    : Token ERC-20 yang akan di-burn
#                     Default = REKT token (Sacred Waste)
#                     Ganti jika ingin burn token lain
# SACRIFICE_CONTRACT: Contract Sacred Waste untuk menerima sacrifice
#                     Ini spesifik untuk platform Sacred Waste, jangan diubah
TOKEN_CONTRACT=0xb3e3c89b8d9c88b1fe96856e382959ee6291ebba
SACRIFICE_CONTRACT=0x9AFeb0e58fa2c76404C3c45eF7Ca5c0503cBaa53
APP_URL=https://app.sacredwaste.io

# ── BURN SETTINGS ──────────────────────────────────────────────────
ENABLE_BURN=true
BURN_COUNT=10
BURN_AMOUNT_MAX=7 # Random 1 - 7 token (default)
BURN_DELAY_MIN=30000
BURN_DELAY_MAX=120000

# ── VOTE SETTINGS ──────────────────────────────────────────────────
ENABLE_VOTE=true
VOTE_COUNT=20
VOTE_DELAY_MIN=5000
VOTE_DELAY_MAX=15000

# ── MULTI-WALLET ───────────────────────────────────────────────────
WALLET_DELAY_MIN=60000
WALLET_DELAY_MAX=300000
SHUFFLE_WALLETS=true

# ── GAS ────────────────────────────────────────────────────────────
GAS_LIMIT_APPROVE=120000
GAS_LIMIT_BURN=350000
GAS_PRICE_MULTIPLIER=1.5

# ── RETRY ──────────────────────────────────────────────────────────
MAX_RETRIES=3
RETRY_DELAY=10000

# ── SCHEDULER ──────────────────────────────────────────────────────
CRON_SCHEDULE=0 9 * * *

# ── BASESCAN API ───────────────────────────────────────────────────
# Gratis di https://basescan.org/apis
BASESCAN_API_KEY=